# Copy this file to .env.local and fill in once the Supabase project exists.
# Not required yet — the dashboard runs on the static roster in lib/roster.js
# until these are set and lib/supabaseClient.js is wired into app/page.js.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for the password gate (middleware.js) to let anyone in — without
# these set, every password attempt fails closed and the site is unreachable.
SITE_PASSWORD=
ADMIN_PASSWORD=
